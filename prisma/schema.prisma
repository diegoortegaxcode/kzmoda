generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Roles ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(ASISTENTE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders         Order[]
  stockMovements StockMovement[]
  reviewedProofs PaymentProof[]  @relation("ProofReviewer")
  notificationReads NotificationRead[]
  passwordResets PasswordResetToken[]

  @@map("users")
}

enum UserRole {
  ADMIN
  ASISTENTE
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  description      String?
  sku              String   @unique
  price            Decimal  @db.Decimal(10, 2)
  costPrice        Decimal  @db.Decimal(10, 2) @map("cost_price")
  cashPrice        Decimal? @db.Decimal(10, 2) @map("cash_price")
  separateDeposit  Decimal? @db.Decimal(10, 2) @map("separate_deposit")
  stock            Int      @default(0)
  minStock         Int      @default(5) @map("min_stock")
  active           Boolean  @default(true)
  images           String[] @default([])
  categoryId       String   @map("category_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  category       Category        @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  stockMovements StockMovement[]
  promotions     Promotion[]

  @@index([categoryId])
  @@index([active])
  @@index([stock])
  @@map("products")
}

// ─── Promotions (descuentos temporales por producto) ──────────────────────────

model Promotion {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  discountPercent Int      @map("discount_percent")
  startsAt        DateTime @default(now()) @map("starts_at")
  endsAt          DateTime @map("ends_at")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([active])
  @@index([endsAt])
  @@map("promotions")
}

// ─── Stock movements ──────────────────────────────────────────────────────────

model StockMovement {
  id        String            @id @default(cuid())
  productId String            @map("product_id")
  userId    String            @map("user_id")
  type      StockMovementType
  qty       Int
  notes     String?
  createdAt DateTime          @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum StockMovementType {
  ENTRADA
  SALIDA
  AJUSTE
  DEVOLUCION
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?
  address      String?
  dni          String?  @unique
  ruc          String?  @unique
  passwordHash String?  @map("password_hash")
  creditLimit  Decimal  @default(0) @db.Decimal(10, 2) @map("credit_limit")
  active       Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders         Order[]
  debts          Debt[]
  paymentProofs  PaymentProof[]
  passwordResets PasswordResetToken[]

  @@index([active])
  @@map("customers")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  customerId String?   @map("customer_id")
  userId     String?   @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Orders (sin pasarela) ────────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  customerId  String      @map("customer_id")
  userId      String      @map("user_id")
  status      OrderStatus @default(PENDIENTE)
  paymentType PaymentType @default(EFECTIVO) @map("payment_type")
  subtotal    Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  paidAmount  Decimal     @default(0) @db.Decimal(10, 2) @map("paid_amount")
  notes       String?
  deliveredAt DateTime?   @map("delivered_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer Customer    @relation(fields: [customerId], references: [id])
  user     User        @relation(fields: [userId], references: [id])
  items    OrderItem[]
  debt     Debt?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDIENTE
  EN_PROCESO
  EN_DESPACHO
  COMPLETADO
  CANCELADO
}

enum PaymentType {
  EFECTIVO
  TRANSFERENCIA
  CREDITO
  YAPE
  PLIN
  SEPARADO
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  qty       Int
  unitPrice Decimal @db.Decimal(10, 2) @map("unit_price")
  subtotal  Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Debts ────────────────────────────────────────────────────────────────────

model Debt {
  id           String     @id @default(cuid())
  customerId   String     @map("customer_id")
  orderId      String?    @unique @map("order_id")
  amount       Decimal    @db.Decimal(10, 2)
  amountPaid   Decimal    @default(0) @db.Decimal(10, 2) @map("amount_paid")
  dueDate      DateTime?  @map("due_date")
  status       DebtStatus @default(PENDIENTE)
  notes        String?
  paidAt       DateTime?  @map("paid_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  customer      Customer       @relation(fields: [customerId], references: [id])
  order         Order?         @relation(fields: [orderId], references: [id])
  payments      DebtPayment[]
  paymentProofs PaymentProof[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("debts")
}

enum DebtStatus {
  PENDIENTE
  PARCIAL
  PAGADO
  VENCIDO
  CONDONADO
}

model DebtPayment {
  id          String      @id @default(cuid())
  debtId      String      @map("debt_id")
  amount      Decimal     @db.Decimal(10, 2)
  paymentType PaymentType @map("payment_type")
  reference   String?
  paidAt      DateTime    @default(now()) @map("paid_at")

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@map("debt_payments")
}

// ─── Payment Proofs (comprobantes del cliente) ────────────────────────────────

model PaymentProof {
  id         String      @id @default(cuid())
  debtId     String      @map("debt_id")
  customerId String      @map("customer_id")
  imageUrl   String      @map("image_url")
  amount     Decimal     @db.Decimal(10, 2)
  paymentType PaymentType @default(TRANSFERENCIA) @map("payment_type")
  status     ProofStatus @default(PENDIENTE)
  notes      String?
  reviewedAt DateTime?   @map("reviewed_at")
  reviewedBy String?     @map("reviewed_by")
  createdAt  DateTime    @default(now()) @map("created_at")

  debt     Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  reviewer User?    @relation("ProofReviewer", fields: [reviewedBy], references: [id])

  @@index([debtId])
  @@index([customerId])
  @@index([status])
  @@map("payment_proofs")
}

enum ProofStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

// ─── Store Settings (singleton row) ──────────────────────────────────────────

model StoreSettings {
  id             String   @id @default("singleton")
  name           String   @default("KZ Tendencias")
  whatsapp       String   @default("992 032 988")
  address        String   @default("")
  instagram      String   @default("")
  catalogTagline String   @default("Catálogo Oficial de Productos") @map("catalog_tagline")
  skuPrefixes    String[] @default([]) @map("sku_prefixes")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String   @map("image_url")
  title     String?
  subtitle  String?
  link      String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model NotificationRead {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  notificationId String   @map("notification_id")
  readAt         DateTime @default(now()) @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([readAt])
  @@map("notification_reads")
}
